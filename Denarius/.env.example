# Copy this file to .env and fill in your own values.
# NEVER commit .env or share it with anyone.
# Get these from https://developer.etrade.com/ after registering an app.

ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=

# E*TRADE account ID (from account list once authenticated) - fill in after first run
ETRADE_ACCOUNT_ID_KEY=

# "sandbox" for paper trading (fake money), "live" for real trading.
# ALWAYS start with sandbox. Only change this once you fully trust the bot.
ETRADE_ENV=sandbox
